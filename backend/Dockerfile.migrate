# ---- Build Stage ----
FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /migrate ./cmd/migrate

# ---- Runtime Stage ----
FROM gcr.io/distroless/static-debian12

WORKDIR /

COPY --from=builder /migrate /migrate

USER nonroot:nonroot

ENTRYPOINT ["/migrate"]
CMD ["up"]
